# ============================================
# CONFIGURACIÓN - COOTRACOVI
# Sistema de Procesos Disciplinarios
# ============================================
# Copie este archivo como .env y complete los valores

# --------------------------------------------
# BASE DE DATOS MYSQL (Para Vercel/Producción)
# --------------------------------------------
# Formato: mysql://usuario:password@servidor:puerto/nombre_base_datos
# Ejemplo para Vercel con base de datos externa:
DATABASE_URL="mysql://cootracovi:Cootracovi2026!@localhost:3306/disciplinarios"

# --------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# --------------------------------------------
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# --------------------------------------------
# AUTENTICACIÓN (NextAuth.js)
# --------------------------------------------
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="cambiar-este-secreto-en-produccion-usar-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------
# URL PÚBLICA (Para enlaces de descargos)
# --------------------------------------------
# Cambiar por la URL real de Vercel cuando esté desplegado
NEXT_PUBLIC_BASE_URL="https://cootracovi-disciplinarios.vercel.app"
